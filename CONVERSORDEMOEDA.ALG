algoritmo "ConversordeMoeda"
var
   R, D, VdoD: real
   C, Q: inteiro
inicio
      C <- 1
      escreva("Quantas conversőes vocę deseja realizar? ")
      leia(Q)
      escreval("")
      enquanto (C <= Q) faca
               escreva("Quanto reais vocę possui? R$")
               leia(R)
               escreva("Qual é o valor atual do dólar? R$1 = US$")
               leia(VdoD)
               D <- R / VdoD
               escreval("")
               escreval("O valor que vocę possui em dólar é US$", D:5:2)
               C <- C + 1
      fimenquanto
      escreval("")
fimalgoritmo